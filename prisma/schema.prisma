// ============ ZEDSTREETWEAR — Prisma schema ============
// Postgres (Supabase / Neon / any Postgres). Set DATABASE_URL in .env.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Enums ----------

enum Role {
  ADMIN
  CUSTOMER
}

enum ProductType {
  simple
  variable
}

enum OrderStatus {
  PENDING
  SHIPPED
  DELIVERED
  CANCELED
  ABANDONED
}

enum OrderState {
  CURRENT
  ARCHIVED
  TRASHED
}

// ---------- Users (replaces "customers") ----------

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String // bcrypt hash
  role      Role     @default(CUSTOMER)
  phone     String?
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// ---------- Categories ----------

model Category {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  image     String?
  parentId  String?
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  Category[] @relation("CategoryTree")
  products  Product[]  @relation("ProductCategories")
  createdAt DateTime   @default(now())

  @@index([parentId])
  @@map("categories")
}

// ---------- Products ----------

model Product {
  id               String       @id @default(cuid())
  name             String
  slug             String       @unique
  shortDescription String?
  description      String?
  // NOTE: stored as Float for a simple JS number pipeline. For strict money
  // precision in production, switch to Decimal @db.Decimal(10,2) or Int cents.
  price            Float
  promoPrice       Float?
  type             ProductType  @default(simple)
  categories       Category[]   @relation("ProductCategories")
  principalImage   String?
  gallery          String[] // extra image URLs
  sizes            String[] // simple products: e.g. ["S","M","L","XL"] or ["OS"]
  color            String?
  stock            Int          @default(0)
  tag              String?
  // Variable products: attribute definitions [{ name, values: [] }].
  attributes       Json?
  // Structured product details shown on the PDP: [{ label, value }].
  additionalInfo   Json?
  variations       ProductVariation[]
  orderItems       OrderItem[]
  bundleItems      BundleItem[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@map("products")
}

// Global, reusable attribute (WooCommerce-style), e.g. Size -> [S, M, L, XL].
// Products pick from these when building variations.
model Attribute {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  values    String[]
  createdAt DateTime @default(now())

  @@map("attributes")
}

// A single variation of a variable product, e.g. { Size: "M", Color: "Black" }.
model ProductVariation {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  options    Json // { "Size": "M", "Color": "Black" }
  price      Float
  promoPrice Float?
  stock      Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([productId])
  @@map("product_variations")
}

// ---------- Orders ----------

model Order {
  id            String      @id @default(cuid())
  seq           Int         @unique // gapless human-facing number, shown as "#<seq>"
  customerName  String? // snapshot — customers are guests, no accounts
  customerEmail String?
  userId        String? // set only if placed by a logged-in admin
  user          User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  items         OrderItem[]
  total     Float
  status    OrderStatus @default(PENDING)
  state     OrderState  @default(CURRENT)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([userId])
  @@map("orders")
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  name      String // snapshot of product name at purchase time
  price     Float // snapshot of unit price
  quantity  Int      @default(1)

  @@index([orderId])
  @@map("order_items")
}

// ---------- Bundles & discounts ----------

model Bundle {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  image     String?
  discount  Int          @default(0) // percent
  active    Boolean      @default(true)
  items     BundleItem[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@map("bundles")
}

model BundleItem {
  id        String   @id @default(cuid())
  bundleId  String
  bundle    Bundle   @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([bundleId])
  @@map("bundle_items")
}
