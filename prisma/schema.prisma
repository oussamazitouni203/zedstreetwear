// ============ ZEDSTREETWEAR — Prisma schema ============
// Postgres (Supabase / Neon / any Postgres). Set DATABASE_URL in .env.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Enums ----------

enum Role {
  ADMIN
  CUSTOMER
}

enum ProductType {
  simple
  variable
}

enum OrderStatus {
  PENDING
  SHIPPED
  DELIVERED
  CANCELED
  ABANDONED
  RETURNED
}

enum OrderState {
  CURRENT
  ARCHIVED
  TRASHED
}

enum CouponType {
  PERCENT
  FIXED
}

enum ShippingMethodType {
  FLAT_RATE
  FREE_SHIPPING
  LOCAL_PICKUP
}

// ---------- Users (replaces "customers") ----------

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String // bcrypt hash
  role      Role     @default(CUSTOMER)
  phone     String?
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// ---------- Categories ----------

model Category {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  image     String?
  parentId  String?
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  Category[] @relation("CategoryTree")
  products  Product[]  @relation("ProductCategories")
  createdAt DateTime   @default(now())

  @@index([parentId])
  @@map("categories")
}

// ---------- Products ----------

model Product {
  id               String       @id @default(cuid())
  num              Int          @unique @default(autoincrement()) // human id → PRD-00001
  name             String
  slug             String       @unique
  shortDescription String?
  description      String?
  // NOTE: stored as Float for a simple JS number pipeline. For strict money
  // precision in production, switch to Decimal @db.Decimal(10,2) or Int cents.
  price            Float
  promoPrice       Float?
  type             ProductType  @default(simple)
  categories       Category[]   @relation("ProductCategories")
  principalImage   String?
  gallery          String[] // extra image URLs
  sizes            String[] // simple products: e.g. ["S","M","L","XL"] or ["OS"]
  color            String?
  stock            Int          @default(0)
  tag              String?
  shippingClassId  String?
  shippingClass    ShippingClass? @relation(fields: [shippingClassId], references: [id], onDelete: SetNull)
  // Variable products: attribute definitions [{ name, values: [] }].
  attributes       Json?
  // Structured product details shown on the PDP: [{ label, value }].
  additionalInfo   Json?
  variations       ProductVariation[]
  orderItems       OrderItem[]
  bundleItems      BundleItem[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([shippingClassId])
  @@map("products")
}

// Global, reusable attribute (WooCommerce-style), e.g. Size -> [S, M, L, XL].
// Products pick from these when building variations.
model Attribute {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  values    String[]
  createdAt DateTime @default(now())

  @@map("attributes")
}

// A single variation of a variable product, e.g. { Size: "M", Color: "Black" }.
model ProductVariation {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  options    Json // { "Size": "M", "Color": "Black" }
  price      Float
  promoPrice Float?
  stock      Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([productId])
  @@map("product_variations")
}

// ---------- Orders ----------

model Order {
  id            String      @id @default(cuid())
  seq           Int         @unique // gapless human-facing number, shown as "#<seq>"
  customerName  String? // snapshot — customers are guests, no accounts
  customerEmail String?
  userId        String? // set only if placed by a logged-in admin
  user          User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  items         OrderItem[]
  total     Float
  shippingRegion String? // wilaya chosen at checkout
  shippingMethod String? // method title snapshot, e.g. "Flat rate"
  shippingCost   Float?  // shipping charged (null = legacy/unknown)
  status    OrderStatus @default(PENDING)
  state     OrderState  @default(CURRENT)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([userId])
  @@map("orders")
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  name      String // snapshot of product name at purchase time
  price     Float // snapshot of unit price
  quantity  Int      @default(1)

  @@index([orderId])
  @@map("order_items")
}

// ---------- Bundles & discounts ----------

model Bundle {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  image     String?
  discount  Int          @default(0) // percent
  active    Boolean      @default(true)
  items     BundleItem[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@map("bundles")
}

model BundleItem {
  id        String   @id @default(cuid())
  bundleId  String
  bundle    Bundle   @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([bundleId])
  @@map("bundle_items")
}

// ---------- Coupons ----------

model Coupon {
  id         String     @id @default(cuid())
  code       String     @unique // stored uppercase, entered at checkout
  type       CouponType @default(PERCENT)
  value      Float // percent (0–100) or fixed amount off
  minSpend   Float? // minimum order subtotal to qualify
  usageLimit Int? // max total redemptions (null = unlimited)
  usedCount  Int        @default(0)
  startsAt   DateTime? // becomes valid on this day (null = immediately)
  expiresAt  DateTime? // last valid day (null = never)
  active     Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@map("coupons")
}

// ---------- Shipping (WooCommerce-style zones, methods, classes) ----------

// A geographic zone: a set of regions (wilayas) with its own shipping methods.
// Orders match the first zone (by `order`) that covers the destination region;
// the `isDefault` zone is the "Rest of the world" fallback (no regions).
model ShippingZone {
  id        String           @id @default(cuid())
  name      String
  regions   String[] // wilaya names this zone covers
  isDefault Boolean          @default(false)
  order     Int              @default(0) // lower = matched first
  methods   ShippingMethod[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@map("shipping_zones")
}

// A shipping option inside a zone (Flat rate / Free shipping / Local pickup).
model ShippingMethod {
  id             String             @id @default(cuid())
  zoneId         String
  zone           ShippingZone       @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  type           ShippingMethodType @default(FLAT_RATE)
  title          String
  enabled        Boolean            @default(true)
  cost           Float              @default(0) // flat-rate base / local-pickup fee
  minAmount      Float? // free shipping: minimum order subtotal required
  requiresCoupon Boolean            @default(false) // free shipping: requires a free-shipping coupon
  classCosts     Json? // flat rate per-class surcharge: { [shippingClassId]: number }
  order          Int                @default(0)
  createdAt      DateTime           @default(now())

  @@index([zoneId])
  @@map("shipping_methods")
}

// Groups products so flat-rate methods can charge different amounts per class.
model ShippingClass {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())

  @@map("shipping_classes")
}

// ---------- Store settings (singleton row, id = "store") ----------

model Setting {
  id        String   @id @default("store")
  data      Json     @default("{}") // { general: {...}, shipping: {...}, ... }
  updatedAt DateTime @updatedAt

  @@map("settings")
}
