# ---- Database (Postgres: Supabase / Neon / Railway) ----
# Supabase: use the "Connection string" (URI) from Project Settings > Database.
#   Use the pooled 6543 port for the app, and the direct 5432 port for migrations.
# Neon:     copy the connection string from the dashboard (includes ?sslmode=require).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# ---- Auth ----
# Generate a strong value, e.g.:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="replace-with-a-long-random-string"

# ---- Instagram feed (optional) ----
# Long-lived Instagram Graph API token (Business/Creator account + linked FB Page).
# Leave unset to fall back to placeholder tiles. Refresh the token before it expires (~60 days).
INSTAGRAM_ACCESS_TOKEN=""
